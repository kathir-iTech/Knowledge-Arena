rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS: consolidated block
    // Teachers (emails ending with @staffs.com) may LIST and READ all users.
    // Regular authenticated users may read/create/update only their own user document.
    match /users/{userId} {
      // allow teachers to list and get documents in /users
      allow list, get: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@staffs\\.com$');

      // allow user to read/create/update their own user doc
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      allow delete: if false;
    }

    match /battleRooms/{roomCode} {
      // READ: Any authenticated user can read the battle room.
      allow read: if request.auth != null;

      // CREATE: Only authenticated teachers can create a battle room.
      allow create: if request.auth != null && request.auth.token.email.matches('.*@staffs\\.com$');

      // UPDATE: 
      // 1. A teacher who owns the room can update anything.
      // 2. A student can ONLY update the studentIds field to add themselves.
      allow update: if request.auth != null && (
        (
          // Teacher access
          resource.data.teacherId == request.auth.uid
        ) || (
          // Student joining access
          request.resource.data.keys().hasOnly(['studentIds']) &&
          request.resource.data.studentIds == resource.data.studentIds.union([request.auth.uid])
        )
      );

      // DELETE: Only the teacher who created the room can delete it.
      allow delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
    }

    // BATTLE RESULTS
    match /battleResults/{resultId} {
        allow read, write: if request.auth != null;
    }


    // QUIZZES & QUESTIONS
    match /quizzes/{quizId} {
      allow read: if request.auth != null;

      allow create, update, delete: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@staffs\\.com$');

      match /questions/{qId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email.matches('.*@staffs\\.com$');
      }
    }
  }
}
