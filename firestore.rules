
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS
    // A user can read and write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // BATTLE ROOMS
    // Any authenticated user can read a battle room to get its details.
    // Only teachers can create new battle rooms.
    // The owning teacher can update/delete the room.
    // Students can update a room ONLY to add themselves to the studentIds list.
    match /battleRooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid;
      allow update: if request.auth != null && (
        // Case 1: The user is the teacher who owns the room. They can make any change.
        resource.data.teacherId == request.auth.uid ||
        
        // Case 2: The user is a student joining the room.
        // This is the only operation they can perform.
        (
          // They must be adding themselves to the studentIds list.
          request.resource.data.studentIds == resource.data.studentIds.concat([request.auth.uid]) &&
          // No other fields can be changed by the student.
          request.resource.data.quiz == resource.data.quiz &&
          request.resource.data.teacherId == resource.data.teacherId &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.currentQuestionIndex == resource.data.currentQuestionIndex &&
          request.resource.data.startTime == resource.data.startTime &&
          request.resource.data.battleResultIds == resource.data.battleResultIds &&
          request.resource.data.createdAt == resource.data.createdAt
        )
      );
      allow delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
    }

    // BATTLE RESULTS
    // Any authenticated user can read results (for leaderboards).
    // Users can only create their own results. Results are immutable once created.
    match /battleResults/{resultId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if false; 
    }
  }
}
