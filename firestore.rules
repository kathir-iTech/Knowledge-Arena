
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isCommander() {
      return isSignedIn() && getRole() == 'commander';
    }

    function isExecutive() {
      return isSignedIn() && getRole() == 'executive';
    }

    function isTeacher() {
      return isSignedIn() && getRole() == 'commander';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isQuizCreator(quizId) {
      let quizPath = /databases/$(database)/documents/quizzes/$(quizId);
      return isSignedIn() && exists(quizPath) && get(quizPath).data.created_by == request.auth.uid;
    }

    function isNotBlocked(quizId, userId) {
      let partPath = /databases/$(database)/documents/quizzes/$(quizId)/participants/$(userId);
      return !exists(partPath) || get(partPath).data.status != 'blocked';
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      // Self-signup: only gladiator role allowed (no privilege escalation)
      allow create: if isOwner(userId) && request.resource.data.role == 'gladiator';
      // Commander/Executive creation bypasses public rules — done via Admin SDK / API
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create: if isTeacher();
      allow update, delete: if isQuizCreator(quizId);

      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow create: if isQuizCreator(quizId);
        allow update, delete: if isQuizCreator(quizId);

        match /submissions/{userId} {
          allow read: if isQuizCreator(quizId) || isOwner(userId);
          allow create: if isOwner(userId) && isNotBlocked(quizId, userId);
          allow delete: if isQuizCreator(quizId);
        }
      }

      match /answerKeys/{questionId} {
        allow read: if isQuizCreator(quizId) || (isSignedIn() && get(/databases/$(database)/documents/quizzes/$(quizId)).data.status == 'finished');
        allow create: if isQuizCreator(quizId);
        allow update, delete: if isQuizCreator(quizId);
      }

      match /participants/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId);
        // Teacher can update everyone (block/reset), students can only increment violations
        // or block themselves (violations_count + status=blocked) in a single write
        allow update: if isQuizCreator(quizId) || (
          isOwner(userId) &&
          request.resource.data.violations_count > resource.data.violations_count &&
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['violations_count']) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['violations_count', 'status']) &&
              request.resource.data.status == 'blocked'
            )
          )
        );
        allow delete: if isQuizCreator(quizId);
      }
    }
  }

  // --- Executive Requests ---
  match /executive_requests/{requestId} {
    allow read: if isSignedIn() && (getRole() == 'executive' || (getRole() == 'commander' && resource.data.commanderId == request.auth.uid));
    allow create: if isSignedIn() && getRole() == 'commander';
    allow update: if isSignedIn() && getRole() == 'executive';
    allow delete: if false;
  }

  // --- Question Bank ---
  match /question_bank/{questionId} {
    allow read: if isSignedIn();
    allow create, update, delete: if isSignedIn() && getRole() == 'executive';
  }

  // --- Platform Settings ---
  match /platform_settings/{docId} {
    allow read: if isSignedIn() && getRole() == 'executive';
    allow write: if isSignedIn() && getRole() == 'executive';
  }

  // Collection group queries for student history
  match /{path=**}/participants/{userId} {
    allow read: if request.auth != null;
  }
}
