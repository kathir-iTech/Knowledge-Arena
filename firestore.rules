
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isTeacher() {
      return isSignedIn() && getRole() == 'teacher';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isQuizCreator(quizId) {
      let quizPath = /databases/$(database)/documents/quizzes/$(quizId);
      return isSignedIn() && exists(quizPath) && get(quizPath).data.created_by == request.auth.uid;
    }

    function isNotBlocked(quizId, userId) {
      let partPath = /databases/$(database)/documents/quizzes/$(quizId)/participants/$(userId);
      return !exists(partPath) || get(partPath).data.status != 'blocked';
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.role in ['teacher', 'student'];
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create: if isTeacher();
      allow update, delete: if isQuizCreator(quizId);

      match /questions/{questionId} {
        allow read: if isSignedIn();
        // Allow creation if the user is a teacher (needed for initial batch)
        allow create: if isTeacher();
        allow update, delete: if isQuizCreator(quizId);

        match /submissions/{userId} {
          allow read: if isQuizCreator(quizId) || isOwner(userId);
          allow create: if isOwner(userId) && isNotBlocked(quizId, userId);
          allow delete: if isQuizCreator(quizId);
        }
      }

      match /answerKeys/{questionId} {
        allow read: if isSignedIn();
        allow create: if isTeacher();
        allow update, delete: if isQuizCreator(quizId);
      }

      match /participants/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId);
        // Teacher can update everyone (block/reset), students can only increment their own violations
        allow update: if isQuizCreator(quizId) || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['violations_count']) && request.resource.data.violations_count > resource.data.violations_count);
        allow delete: if isQuizCreator(quizId);
      }
    }
  }

  // Collection group queries for student history
  match /{path=**}/participants/{userId} {
    allow read: if isSignedIn();
  }
}
