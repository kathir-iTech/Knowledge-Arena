
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isCommander() {
      return isSignedIn() && getRole() == 'commander';
    }

    function isExecutive() {
      return isSignedIn() && getRole() == 'executive';
    }

    function isTeacher() {
      return isSignedIn() && getRole() == 'commander';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isQuizCreator(quizId) {
      let quizPath = /databases/$(database)/documents/quizzes/$(quizId);
      return isSignedIn() && exists(quizPath) && get(quizPath).data.created_by == request.auth.uid;
    }

    // Batch-aware version: uses getAfter()/existsAfter() so subcollection creates
    // within an atomic writeBatch can see the parent quiz being created in the same batch.
    function isQuizCreatorAfter(quizId) {
      let quizPath = /databases/$(database)/documents/quizzes/$(quizId);
      return isSignedIn() && existsAfter(quizPath) && getAfter(quizPath).data.created_by == request.auth.uid;
    }

    function isNotBlocked(quizId, userId) {
      let partPath = /databases/$(database)/documents/quizzes/$(quizId)/participants/$(userId);
      return !exists(partPath) || get(partPath).data.status != 'blocked';
    }

    function isQuizParticipant(quizId, userId) {
      let partPath = /databases/$(database)/documents/quizzes/$(quizId)/participants/$(userId);
      return isSignedIn() && exists(partPath);
    }

    function canReadArena(quizId) {
      let quizPath = /databases/$(database)/documents/quizzes/$(quizId);
      return isSignedIn() && exists(quizPath) && (
        get(quizPath).data.status != 'finished' ||
        isQuizCreator(quizId) ||
        isQuizParticipant(quizId, request.auth.uid)
      );
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      // Self-signup: only gladiator role allowed (no privilege escalation)
      allow create: if isOwner(userId) && request.resource.data.role == 'gladiator';
      // Commander/Executive creation bypasses public rules — done via Admin SDK / API
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create: if isTeacher();
      allow update, delete: if isQuizCreator(quizId);

      match /questions/{questionId} {
        allow read: if isExecutive() || canReadArena(quizId);
        // isQuizCreatorAfter supports atomic writeBatch where parent quiz is created
        // in the same batch — getAfter() sees the pending parent.
        allow create: if isQuizCreator(quizId) || isQuizCreatorAfter(quizId);
        allow update, delete: if isQuizCreator(quizId);

        match /submissions/{userId} {
          allow read: if isExecutive() || isQuizCreator(quizId) || isOwner(userId);
          allow create: if isOwner(userId) && isNotBlocked(quizId, userId)
            && request.resource.data.selected_option >= 0
            && request.resource.data.selected_option <= 3
            && request.resource.data.keys().hasOnly(['question_id', 'selected_option', 'submittedAt', 'clientTime'])
            && request.resource.data.submittedAt == request.time;
          allow update: if false;
          allow delete: if isQuizCreator(quizId);
        }
      }

      match /answerKeys/{questionId} {
        allow read: if isExecutive() || isQuizCreator(quizId) || (
          isSignedIn() &&
          get(/databases/$(database)/documents/quizzes/$(quizId)).data.status == 'finished' &&
          isQuizParticipant(quizId, request.auth.uid)
        );
        // isQuizCreatorAfter supports atomic writeBatch where parent quiz is created
        // in the same batch.
        allow create: if isQuizCreator(quizId) || isQuizCreatorAfter(quizId);
        allow update, delete: if isQuizCreator(quizId);
      }

      match /participants/{userId} {
        allow read: if isExecutive() || canReadArena(quizId);
        // isOwner(userId) handles both Commander creating their own participant in
        // the arena creation batch AND Gladiators joining later.
        // getAfter(quizPath) supports atomic batch where parent quiz is created
        // in the same batch — getAfter() sees the pending parent with status 'waiting'.
        allow create: if isOwner(userId)
          && isNotBlocked(quizId, userId)
          && request.resource.data.user_id == userId
          && request.resource.data.lastSeen == request.time
          && getAfter(/databases/$(database)/documents/quizzes/$(quizId)).data.status == 'waiting';
        // Teacher can update everyone (block/reset), students can only increment violations
        // or block themselves (violations_count + status=blocked) in a single write,
        // or send heartbeat (lastSeen) updates.
        allow update: if isQuizCreator(quizId) || (
          isOwner(userId) && (
            (
              request.resource.data.violations_count > resource.data.violations_count &&
              (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['violations_count']) ||
                (
                  request.resource.data.diff(resource.data).affectedKeys().hasOnly(['violations_count', 'status']) &&
                  request.resource.data.status == 'blocked'
                )
              )
            ) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen'])
            && request.resource.data.lastSeen == request.time
          )
        );
        allow delete: if isQuizCreator(quizId) || (
          isOwner(userId) &&
          get(/databases/$(database)/documents/quizzes/$(quizId)).data.status == 'waiting' &&
          resource.data.status != 'blocked'
        );
      }
    }
  }

  // --- Executive Requests ---
  match /executive_requests/{requestId} {
    allow read: if isSignedIn() && (getRole() == 'executive' || (getRole() == 'commander' && resource.data.commanderId == request.auth.uid));
    allow create: if isSignedIn() && getRole() == 'commander';
    allow update: if isSignedIn() && getRole() == 'executive';
    allow delete: if false;
  }

  // --- Question Bank ---
  match /question_bank/{questionId} {
    allow read: if isSignedIn();
    allow create, update, delete: if isSignedIn() && getRole() == 'executive';
  }

  // --- Platform Settings ---
  match /platform_settings/{docId} {
    allow read: if isSignedIn() && getRole() == 'executive';
    allow write: if isSignedIn() && getRole() == 'executive';
  }

  // Collection group queries for student history
  match /{path=**}/participants/{userId} {
    allow read: if request.auth != null && request.auth.uid == userId;
  }
}
