
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS
    // Anyone can read their own user document.
    // Teachers can read all user documents.
    // Users can create and update their own document.
    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Teacher');
      allow list: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Teacher';
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // BATTLE ROOMS
    // Any authenticated user can read a battle room.
    // Only teachers can create battle rooms.
    // Only the teacher who owns the room can update it to start/end it.
    // Students can join by adding their ID to the studentIds list.
    match /battleRooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.teacherId == request.auth.uid && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Teacher';
      allow update: if request.auth != null && (
        // Teacher can change status, question index, etc.
        (resource.data.teacherId == request.auth.uid) ||
        // Student can ONLY add themselves to the studentIds array
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds']) &&
          request.resource.data.studentIds.size() == resource.data.studentIds.size() + 1 &&
          request.auth.uid in request.resource.data.studentIds
        )
      );
      allow delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
    }

    // BATTLE RESULTS
    // Users can create their own results.
    // Any authenticated user can read results (for leaderboards).
    match /battleResults/{resultId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
