
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isTeacher() {
      return isSignedIn() && getRole() == 'Teacher';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isQuizCreator(quizId) {
      let quizPath = /databases/$(database)/documents/quizzes/$(quizId);
      return isSignedIn() && exists(quizPath) && get(quizPath).data.createdBy == request.auth.uid;
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create: if isTeacher();
      allow update, delete: if isQuizCreator(quizId);

      match /questions/{questionId} {
        allow read: if isSignedIn();
        // Allow creation if the user is a teacher (needed for initial batch)
        allow create: if isTeacher();
        allow update, delete: if isQuizCreator(quizId);

        match /submissions/{userId} {
          allow read: if isQuizCreator(quizId);
          allow create: if isOwner(userId);
          allow delete: if isQuizCreator(quizId);
        }
      }

      match /answerKeys/{questionId} {
        allow read: if isQuizCreator(quizId);
        allow create: if isTeacher();
        allow update, delete: if isQuizCreator(quizId);
      }

      match /participants/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId);
        // Teacher can update everyone (block/reset), students can update themselves (violations)
        allow update: if isQuizCreator(quizId) || isOwner(userId);
        allow delete: if isQuizCreator(quizId);
      }
    }
  }
}
