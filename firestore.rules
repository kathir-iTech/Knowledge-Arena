rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS COLLECTION
    // Authenticated users can read any user profile (for leaderboards, etc.)
    // Users can only create and update their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // BATTLE ROOMS
    // Authenticated users can read any room (to see participants).
    // A user can create a room.
    // A user can join a room (update studentIds array).
    // The teacher who created the room can update its status.
    match /battleRooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // Allow student to add themselves to the room
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly('studentIds') &&
         request.resource.data.studentIds.hasAll(resource.data.studentIds) &&
         request.resource.data.studentIds.size() == resource.data.studentIds.size() + 1 &&
         request.auth.uid in request.resource.data.studentIds) ||
        // Allow teacher to start/finish battle or add results
        (request.auth.uid == resource.data.teacherId &&
         (request.resource.data.diff(resource.data).affectedKeys().hasOnly('status') ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly('startTime') ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly('currentQuestionIndex') ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly('battleResultIds')))
      );
    }
    
    // BATTLE RESULTS
    // Students can create their own battle result.
    // Authenticated users can read any result (for leaderboards).
    match /battleResults/{resultId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
    }

    // TEACHER'S QUIZZES
    // This is a private collection for each teacher.
    match /users/{teacherId}/quizzes/{quizId} {
        allow read, write: if request.auth != null && request.auth.uid == teacherId;
    }
  }
}