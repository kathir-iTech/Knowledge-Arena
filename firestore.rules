
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS: teachers may read all users for result display; users may read/write only their own doc
    match /users/{userId} {
      allow get: if request.auth != null;
      allow create, update: if request.auth.uid == userId;
      allow delete: if false;
    }
    
    // BATTLE ROOMS
    match /battleRooms/{roomId} {
      // Any authenticated user can read a room to get its details
      allow read: if request.auth != null;
      
      // Only a user with the 'Teacher' role can create a room
      allow create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Teacher';
      
      // Allow a user to update a room ONLY to add their UID to the studentIds list.
      // This is a secure way to let students join a room.
      allow update: if request.auth != null &&
      				// Ensure the user is a student
      				get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Student' &&
                    // Ensure the ONLY field being changed is studentIds
                    request.resource.data.keys().removeAll(['studentIds']).size() == resource.data.keys().removeAll(['studentIds']).size() &&
                    // Ensure they are only adding themselves to the list
                    request.resource.data.studentIds == resource.data.studentIds.union([request.auth.uid]);

      // Only the teacher who created the room can delete it
      allow delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
    }
    
    // BATTLE RESULTS
    // Students can create their own battle result.
    // Authenticated users can read any result (for leaderboards).
    match /battleResults/{resultId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
    }
    
  }
}
