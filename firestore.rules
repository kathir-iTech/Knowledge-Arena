
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isTeacher() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Teacher';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isRoomTeacher(roomId) {
      return isTeacher() && get(/databases/$(database)/documents/battleRooms/$(roomId)).data.teacherId == request.auth.uid;
    }

    // USER--
    // Users can create their own profile.
    // Users can read and update their own profile.
    // Signed-in users can read other users' public profiles (for names/avatars).
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow get: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // QUIZZES
    // Only teachers can create, read, update, or delete quizzes.
    // Quizzes are owned by the teacher who created them.
    match /quizzes/{quizId} {
      allow read, write: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    // BATTLE ROOMS
    // Only teachers can create battle rooms.
    // The hosting teacher can update or delete the room.
    // Any signed-in user can read a room to join it.
    match /battleRooms/{roomId} {
      allow get, list: if isSignedIn();
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isRoomTeacher(roomId);
    }
    
    // BATTLE PARTICIPANTS
    // A student can create their own participation record to join a battle.
    // A student can update their own record (e.g., to submit answers).
    // A student CANNOT update their own `isBlocked` or `malpracticeCount` status.
    // The hosting teacher can read all participant data and can update a student's record to reset a malpractice block.
    match /battleRooms/{roomId}/participants/{participantId} {
      allow get: if isSignedIn() && (isOwner(participantId) || isRoomTeacher(roomId));
      allow list: if isRoomTeacher(roomId);
      allow create: if isOwner(participantId);
      
      allow update: if isSignedIn() && (
        // Case 1: Student updating their own answers.
        // They can change anything EXCEPT their blocked status.
        (isOwner(participantId) && request.resource.data.isBlocked == resource.data.isBlocked && request.resource.data.malpracticeCount == resource.data.malpracticeCount) ||
        // Case 2: Teacher resetting a student's malpractice block.
        (isRoomTeacher(roomId))
      );
    }
  }
}

