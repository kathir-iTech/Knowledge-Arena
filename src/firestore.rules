
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isTeacher() {
      return isSignedIn() && getRole() == 'Teacher';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user is the creator of the specified quiz.
    function isQuizCreator(quizId) {
      let quizPath = /databases/$(database)/documents/quizzes/$(quizId);
      return isSignedIn() && exists(quizPath) && get(quizPath).data.createdBy == request.auth.uid;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      // Allow any teacher to create a quiz.
      allow create: if isTeacher();
      // Only the creator can update or delete the main quiz doc.
      allow update, delete: if isQuizCreator(quizId);

      match /questions/{questionId} {
        allow read: if isSignedIn();
        // Teachers can create questions (essential for the initial batch).
        allow create: if isTeacher();
        allow update, delete: if isQuizCreator(quizId);

        match /submissions/{userId} {
          // Quiz creator can see all submissions.
          allow read: if isQuizCreator(quizId);
          // Students can create their own submissions.
          allow create: if isOwner(userId);
          // Quiz creator can purge submissions (resetting room).
          allow delete: if isQuizCreator(quizId);
        }
      }

      match /answerKeys/{questionId} {
        // Only the teacher/creator can see the answer keys.
        allow read: if isQuizCreator(quizId);
        // Teachers can create keys.
        allow create: if isTeacher();
        allow update, delete: if isQuizCreator(quizId);
      }

      match /participants/{userId} {
        allow read: if isSignedIn();
        // Students can join themselves.
        allow create: if isOwner(userId);
        // Teacher can update everyone (reset/block); students can update themselves (malpractice tracking).
        allow update: if isQuizCreator(quizId) || isOwner(userId);
        allow delete: if isQuizCreator(quizId);
      }
    }
  }
}
