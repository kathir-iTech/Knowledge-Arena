
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isTeacher() {
      // Check role from the user's own document, which they have read access to.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Teacher';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isRoomTeacher(roomId) {
      // Must be a teacher and the teacherId on the room document must match their UID.
      return isTeacher() && get(/databases/$(database)/documents/battleRooms/$(roomId)).data.teacherId == request.auth.uid;
    }
    
    function isRoomFinished(roomId) {
      return get(/databases/$(database)/documents/battleRooms/$(roomId)).data.status == 'finished';
    }
    
    function isRoomInProgress(roomId) {
      let roomData = get(/databases/$(database)/documents/battleRooms/$(roomId)).data;
      return roomData.status == 'in-progress';
    }

    // USER PROFILES
    // Users can create their own profile upon signup.
    // Users can read and update their own profile data (e.g., avatar).
    // Any signed-in user can read another user's profile (needed for displaying names/avatars in leaderboards).
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow get: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if false; // Do not allow users to delete their profiles.
    }

    // BATTLE ROOMS
    // Only teachers can create battle rooms.
    // The hosting teacher can update the room status (start/finish) or delete the room.
    // Any signed-in user can read a room to join it or view its status.
    match /battleRooms/{roomId} {
      allow get: if isSignedIn();
      allow list: if isTeacher(); // Only teachers can list rooms on their dashboard.
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isRoomTeacher(roomId);
    }
    
    // BATTLE PARTICIPANTS
    // A student can create their own participation record to join a battle.
    // A student can update their own record to submit answers.
    // The hosting teacher can read all participant data.
    // ANYONE can read the full participant list for a FINISHED or WAITING battle.
    match /battleRooms/{roomId}/participants/{participantId} {
      allow get: if isSignedIn(); 
      allow list: if isRoomTeacher(roomId) || isRoomFinished(roomId);
      allow create: if isOwner(participantId) && isRoomInProgress(roomId);
      
      allow update: if isSignedIn() && (
        // Case 1: Student updating their own answers and score.
        // They can change their answers array and total score, but not other sensitive fields.
        (isOwner(participantId) && 
         isRoomInProgress(roomId) &&
         request.resource.data.isBlocked == resource.data.isBlocked &&
         request.resource.data.malpracticeCount == resource.data.malpracticeCount
        ) ||
        // Case 1.1: Student's client reports malpractice.
        // It can increment the count by 1 and set isBlocked to true.
        (isOwner(participantId) && 
         isRoomInProgress(roomId) &&
         request.resource.data.malpracticeCount == resource.data.malpracticeCount + 1 &&
         request.resource.data.isBlocked == true
        ) ||
        // Case 2: Teacher resetting a student's malpractice block.
        // Teacher can set isBlocked to false and reset malpracticeCount.
        (isRoomTeacher(roomId))
      );

      allow delete: if isRoomTeacher(roomId);
    }
  }
}
