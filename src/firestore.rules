rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS: consolidated block
    // Teachers (emails ending with @staffs.com) may LIST and READ all users.
    // Regular authenticated users may read/create/update only their own user document.
    match /users/{userId} {
      // allow teachers to list and get documents in /users
      allow list, get: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@staffs\\.com$');

      // allow user to read/create/update their own user doc
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      allow delete: if false;
    }

    // BATTLE ROOMS (previously rooms)
    match /battleRooms/{roomCode} {
      allow read, write: if request.auth != null;

      match /participants/{pid} {
        allow read, write: if request.auth != null;
      }
      match /events/{eventId} {
        allow read, write: if request.auth != null;
      }
    }

    // BATTLE RESULTS
    match /battleResults/{resultId} {
        allow read, write: if request.auth != null;
    }


    // QUIZZES & QUESTIONS
    match /quizzes/{quizId} {
      allow read: if request.auth != null;

      allow create, update, delete: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@staffs\\.com$');

      match /questions/{qId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email.matches('.*@staffs\\.com$');
      }
    }
  }
}
