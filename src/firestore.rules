
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isTeacher() {
      // Check role from the user's own document, which they have read access to.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Teacher';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isRoomTeacher(roomId) {
      // Must be a teacher and the teacherId on the room document must match their UID.
      return isTeacher() && get(/databases/$(database)/documents/battleRooms/$(roomId)).data.teacherId == request.auth.uid;
    }
    
    function isRoomFinished(roomId) {
      return get(/databases/$(database)/documents/battleRooms/$(roomId)).data.status == 'finished';
    }
    
    function isRoomInProgress(roomId) {
      let roomData = get(/databases/$(database)/documents/battleRooms/$(roomId)).data;
      return roomData.status == 'in-progress';
    }

    // USER PROFILES
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow get: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // BATTLE ROOMS
    match /battleRooms/{roomId} {
      allow get: if isSignedIn();
      allow list: if isTeacher(); 
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isRoomTeacher(roomId);
    }
    
    // BATTLE PARTICIPANTS
    match /battleRooms/{roomId}/participants/{participantId} {
      allow get: if isSignedIn();
      allow list: if isRoomTeacher(roomId) || isRoomFinished(roomId);
      
      // Allow create only if the document doesn't exist yet and the student owns it.
      allow create: if isOwner(participantId) && !exists(/databases/$(database)/documents/battleRooms/$(roomId)/participants/$(participantId));
      
      allow update: if isSignedIn() && (
        // Case 1: Student updating their own answers/score/status during normal gameplay.
        // Malpractice fields cannot change in this transaction.
        (isOwner(participantId) && 
         isRoomInProgress(roomId) &&
         request.resource.data.isBlocked == resource.data.isBlocked &&
         request.resource.data.malpracticeCount == resource.data.malpracticeCount
        ) ||

        // Case 2: Student client reports a focus loss (malpractice warning OR block).
        (isOwner(participantId) && isRoomInProgress(roomId) &&
          // Malpractice count must increment by exactly 1.
          request.resource.data.malpracticeCount == resource.data.malpracticeCount + 1 &&
          // During this update, other gameplay fields must not change.
          request.resource.data.answers.size() == resource.data.answers.size() &&
          request.resource.data.totalScore == resource.data.totalScore &&
          // isBlocked can either stay the same (for a warning) or be set to true (for a block). It cannot be set to false by the student.
          (request.resource.data.isBlocked == resource.data.isBlocked || request.resource.data.isBlocked == true)
        ) ||
        
        // Case 3: Teacher can reset a student's malpractice block.
        (isRoomTeacher(roomId) &&
         request.resource.data.isBlocked == false &&
         request.resource.data.malpracticeCount == 0
        )
      );

      allow delete: if isRoomTeacher(roomId);
    }
  }
}
