
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isTeacher() {
      return isSignedIn() && getRole() == 'Teacher';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user is the creator of the specified quiz.
    // We use a helper that safely checks for existence to avoid rule errors.
    function isQuizCreator(quizId) {
      let quizPath = /databases/$(database)/documents/quizzes/$(quizId);
      return isSignedIn() && exists(quizPath) && get(quizPath).data.createdBy == request.auth.uid;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create: if isTeacher();
      allow update, delete: if isQuizCreator(quizId);

      match /questions/{questionId} {
        allow read: if isSignedIn();
        // Allow teachers to create questions (needed for the initial creation batch)
        allow create: if isTeacher();
        allow update, delete: if isQuizCreator(quizId);

        match /submissions/{userId} {
          allow read: if isQuizCreator(quizId);
          // Only allow submissions if the quiz is live
          allow create: if isOwner(userId) && get(/databases/$(database)/documents/quizzes/$(quizId)).data.status == 'live';
          allow delete: if isQuizCreator(quizId);
        }
      }

      match /answerKeys/{questionId} {
        // Only the teacher/creator can see the answer keys
        allow read: if isQuizCreator(quizId);
        allow create: if isTeacher();
        allow update, delete: if isQuizCreator(quizId);
      }

      match /participants/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId);
        // Teachers can manage participants; students can update their own status/violations
        allow update: if isQuizCreator(quizId) || isOwner(userId);
        allow delete: if isQuizCreator(quizId);
      }
    }
  }
}
