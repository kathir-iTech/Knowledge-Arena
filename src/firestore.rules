
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isTeacher() {
      return isSignedIn() && getRole() == 'Teacher';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isQuizCreator(quizId) {
      let quizPath = /databases/$(database)/documents/quizzes/$(quizId);
      return isSignedIn() && exists(quizPath) && get(quizPath).data.createdBy == request.auth.uid;
    }

    function isNotBlocked(quizId, userId) {
      let partPath = /databases/$(database)/documents/quizzes/$(quizId)/participants/$(userId);
      return !exists(partPath) || get(partPath).data.status != 'blocked';
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create: if isTeacher();
      allow update, delete: if isQuizCreator(quizId);

      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow create: if isTeacher();
        allow update, delete: if isQuizCreator(quizId);

        match /submissions/{userId} {
          allow read: if isQuizCreator(quizId);
          // Only allow submission if student is not blocked
          allow create: if isOwner(userId) && isNotBlocked(quizId, userId);
          allow delete: if isQuizCreator(quizId);
        }
      }

      match /answerKeys/{questionId} {
        // Absolute Security: Only the Commander can ever read answer keys
        allow read: if isQuizCreator(quizId);
        allow create: if isTeacher();
        allow update, delete: if isQuizCreator(quizId);
      }

      match /participants/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId);
        // Students can only update their own violations, status is teacher-controlled or auto-blocked
        allow update: if isQuizCreator(quizId) || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['violationsCount', 'status']));
        allow delete: if isQuizCreator(quizId);
      }
    }
  }
}
