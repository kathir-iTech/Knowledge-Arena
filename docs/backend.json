
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile stored in Firestore.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user, primarily for UI distinctions. Security is handled by custom claims.",
          "enum": ["Teacher", "Student"]
        },
        "avatar": {
          "type": "string",
          "description": "Emoji representing the user's avatar."
        }
      },
      "required": ["name", "email", "role", "avatar"]
    },
    "Battle": {
      "title": "Battle",
      "description": "The main document for a quiz battle session.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the quiz for this battle."
        },
        "state": {
          "type": "string",
          "description": "The current state of the battle.",
          "enum": ["waiting", "live", "finished"]
        },
        "currentQuestionIndex": {
          "type": "number",
          "description": "The index of the currently active question."
        },
        "questionCount": {
          "type": "number",
          "description": "Total number of questions in the battle."
        },
        "questionStartAt": {
          "type": "number",
          "description": "Server timestamp for when the current question was started."
        },
        "timeLimit": {
          "type": "number",
          "description": "The duration in seconds for the current question."
        },
        "createdBy": {
          "type": "string",
          "description": "The UID of the teacher who created the battle."
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when the room was created."
        }
      },
      "required": ["title", "state", "currentQuestionIndex", "questionCount", "createdBy", "createdAt"]
    },
    "BattleQuestion": {
      "title": "BattleQuestion",
      "description": "A single question within a battle. Publicly readable question data.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timer": {
          "type": "number",
          "description": "The time limit for this question in seconds."
        }
      },
      "required": ["text", "options", "timer"]
    },
    "BattleAnswerKey": {
      "title": "BattleAnswerKey",
      "description": "Server-only document containing the correct answer for a question.",
      "type": "object",
      "properties": {
        "correctOptionIndex": {
          "type": "number"
        }
      },
      "required": ["correctOptionIndex"]
    },
    "BattleParticipant": {
      "title": "BattleParticipant",
      "description": "Represents a user's participation and state within a battle.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["teacher", "student"]
        },
        "score": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["playing", "finished", "blocked"]
        },
        "violationsCount": {
          "type": "number"
        }
      },
      "required": ["name", "avatar", "role", "score", "status", "violationsCount"]
    },
    "BattleAnswer": {
      "title": "BattleAnswer",
      "description": "A student's submitted answer for a single question.",
      "type": "object",
      "properties": {
        "selectedOption": {
          "type": "number"
        },
        "submittedAt": {
          "type": "number"
        }
      },
      "required": ["selectedOption", "submittedAt"]
    },
     "Leaderboard": {
      "title": "Leaderboard",
      "description": "Aggregated and throttled leaderboard data.",
      "type": "object",
      "properties": {
        "topPlayers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "name": { "type": "string" },
              "avatar": { "type": "string" },
              "score": { "type": "number" }
            }
          }
        },
        "updatedAt": {
          "type": "number"
        }
      }
    }
  },
  "auth": {
    "providers": ["password"],
    "customClaims": {
      "role": {
        "type": "string",
        "enum": ["teacher", "student"]
      }
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores public user profile information."
        }
      },
      {
        "path": "/battles/{battleId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Battle" },
          "description": "The root document for a single quiz battle."
        }
      },
      {
        "path": "/battles/{battleId}/questions/{questionId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/BattleQuestion" },
          "description": "Publicly visible data for each question in a battle."
        }
      },
      {
        "path": "/battles/{battleId}/answerKeys/{questionId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/BattleAnswerKey" },
          "description": "Server-only correct answer data for each question."
        }
      },
      {
        "path": "/battles/{battleId}/participants/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/BattleParticipant" },
          "description": "A user's state, score, and status within a battle."
        }
      },
      {
        "path": "/battles/{battleId}/answers/{userId}/{questionId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/BattleAnswer" },
          "description": "A student's submitted answer for a specific question."
        }
      },
      {
        "path": "/battles/{battleId}/violations/{userId}",
        "definition": {
          "schema": { "type": "object", "properties": { "timestamp": { "type": "number" }} },
          "description": "Log of anti-cheating violations reported by the client."
        }
      },
      {
        "path": "/battles/{battleId}/leaderboard/summary",
        "definition": {
            "schema": { "$ref": "#/backend/entities/Leaderboard" },
            "description": "A single document containing aggregated leaderboard data, updated by a server process."
        }
      }
    ]
  }
}
