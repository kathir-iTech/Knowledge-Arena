
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the application, either a Teacher or a Student.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user, matching the Firebase Auth UID."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user.",
          "enum": ["Teacher", "Student"]
        },
        "avatar": {
            "type": "string",
            "description": "Emoji representing the user's avatar."
        }
      },
      "required": ["id", "name", "email", "role", "avatar"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "Represents a set of questions created by a teacher.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the quiz."
        },
        "teacherId": {
          "type": "string",
          "description": "The UID of the teacher who owns this quiz."
        },
        "title": {
          "type": "string",
          "description": "The title of the quiz."
        },
        "questions": {
          "type": "array",
          "description": "An array of question objects.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "options": {
                "type": "array",
                "items": { "type": "string" }
              },
              "correctAnswerIndex": { "type": "number" },
              "timer": { "type": "number" }
            },
            "required": ["id", "text", "options", "correctAnswerIndex", "timer"]
          }
        }
      },
      "required": ["id", "teacherId", "title", "questions"]
    },
    "BattleRoom": {
      "title": "BattleRoom",
      "description": "Represents a live quiz session initiated by a teacher.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the battle room (the room code)."
        },
        "teacherId": {
          "type": "string",
          "description": "The UID of the teacher hosting the battle."
        },
        "quiz": {
          "$ref": "#/backend/entities/Quiz",
          "description": "A denormalized copy of the quiz object for the battle."
        },
        "status": {
          "type": "string",
          "description": "The current status of the battle.",
          "enum": ["waiting", "in-progress", "finished"]
        },
        "currentQuestionIndex": {
          "type": "number",
          "description": "The index of the currently active question."
        },
        "createdAt": {
            "type": "number",
            "description": "Timestamp when the room was created."
        }
      },
      "required": ["id", "teacherId", "quiz", "status", "currentQuestionIndex", "createdAt"]
    },
    "BattleParticipation": {
      "title": "BattleParticipation",
      "description": "Tracks a student's state within a specific battle room.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the participation record."
        },
        "studentId": {
          "type": "string",
          "description": "The UID of the participating student."
        },
        "studentName": {
            "type": "string"
        },
        "studentAvatar": {
            "type": "string"
        },
        "battleRoomId": {
          "type": "string",
          "description": "The ID of the battle room this participation belongs to."
        },
        "answers": {
          "type": "array",
          "description": "An array of the student's answers.",
          "items": {
            "type": "object",
            "properties": {
              "questionId": { "type": "string" },
              "answerIndex": { "type": "number" },
              "isCorrect": { "type": "boolean" },
              "score": { "type": "number" }
            },
            "required": ["questionId", "answerIndex", "isCorrect", "score"]
          }
        },
        "totalScore": {
          "type": "number"
        },
        "malpracticeCount": {
          "type": "number",
          "description": "Number of times malpractice was detected."
        },
        "isBlocked": {
          "type": "boolean",
          "description": "If true, the student is blocked from continuing the quiz."
        }
      },
      "required": ["id", "studentId", "studentName", "studentAvatar", "battleRoomId", "answers", "totalScore", "malpracticeCount", "isBlocked"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores public profile information for all users."
        }
      },
      {
        "path": "/quizzes/{quizId}",
        "definition": {
          "entityName": "Quiz",
          "schema": {
            "$ref": "#/backend/entities/Quiz"
          },
          "description": "Top-level collection for all quizzes created by teachers."
        }
      },
      {
        "path": "/battleRooms/{battleRoomId}",
        "definition": {
          "entityName": "BattleRoom",
          "schema": {
            "$ref": "#/backend/entities/BattleRoom"
          },
          "description": "Top-level collection for all live battle sessions."
        }
      },
      {
        "path": "/battleRooms/{battleRoomId}/participants/{participantId}",
        "definition": {
          "entityName": "BattleParticipation",
          "schema": {
            "$ref": "#/backend/entities/BattleParticipation"
          },
          "description": "Sub-collection storing participation records for each student in a battle."
        }
      }
    ]
  }
}
