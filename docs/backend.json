
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile stored in Firestore.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user, primarily for UI distinctions. Security is handled by custom claims.",
          "enum": ["Teacher", "Student"]
        },
        "avatar": {
          "type": "string",
          "description": "Emoji representing the user's avatar."
        }
      },
      "required": ["name", "email", "role", "avatar"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "The main document for a quiz session.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the quiz for this session."
        },
        "status": {
          "type": "string",
          "description": "The current state of the quiz.",
          "enum": ["waiting", "live", "finished"]
        },
        "currentQuestionIndex": {
          "type": "number",
          "description": "The index of the currently active question."
        },
        "questionCount": {
          "type": "number",
          "description": "Total number of questions in the quiz."
        },
        "questionStartAt": {
          "type": "number",
          "description": "Server timestamp for when the current question was started."
        },
        "timeLimit": {
          "type": "number",
          "description": "The duration in seconds for the current question."
        },
        "createdBy": {
          "type": "string",
          "description": "The UID of the teacher who created the quiz."
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when the room was created."
        }
      },
      "required": ["title", "status", "currentQuestionIndex", "questionCount", "createdBy", "createdAt"]
    },
    "QuizQuestion": {
      "title": "QuizQuestion",
      "description": "A single question within a quiz. Publicly readable question data.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timer": {
          "type": "number",
          "description": "The time limit for this question in seconds."
        }
      },
      "required": ["text", "options", "timer"]
    },
    "QuizAnswerKey": {
      "title": "QuizAnswerKey",
      "description": "Server-only document containing the correct answer for a question.",
      "type": "object",
      "properties": {
        "correctOptionIndex": {
          "type": "number"
        }
      },
      "required": ["correctOptionIndex"]
    },
    "QuizParticipant": {
      "title": "QuizParticipant",
      "description": "Represents a user's participation and state within a quiz.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["teacher", "student"]
        },
        "score": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["playing", "finished", "blocked"]
        },
        "violationsCount": {
          "type": "number"
        }
      },
      "required": ["name", "avatar", "role", "score", "status", "violationsCount"]
    },
    "QuizSubmission": {
      "title": "QuizSubmission",
      "description": "A student's submitted answer for a single question.",
      "type": "object",
      "properties": {
        "selectedOption": {
          "type": "number"
        },
        "submittedAt": {
          "type": "number"
        }
      },
      "required": ["selectedOption", "submittedAt"]
    }
  },
  "auth": {
    "providers": ["password"],
    "customClaims": {
      "role": {
        "type": "string",
        "enum": ["teacher", "student"]
      }
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores public user profile information."
        }
      },
      {
        "path": "/quizzes/{quizId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Quiz" },
          "description": "The root document for a single quiz session."
        }
      },
      {
        "path": "/quizzes/{quizId}/questions/{questionId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/QuizQuestion" },
          "description": "Publicly visible data for each question in a quiz."
        }
      },
      {
        "path": "/quizzes/{quizId}/answerKeys/{questionId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/QuizAnswerKey" },
          "description": "Server-only correct answer data for each question."
        }
      },
      {
        "path": "/quizzes/{quizId}/participants/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/QuizParticipant" },
          "description": "A user's state, score, and status within a quiz."
        }
      },
      {
        "path": "/quizzes/{quizId}/questions/{questionId}/submissions/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/QuizSubmission" },
          "description": "A student's submitted answer for a specific question. The document ID is the student's UID."
        }
      }
    ]
  }
}
