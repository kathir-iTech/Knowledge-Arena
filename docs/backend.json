
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile stored in Firestore.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user.",
          "enum": ["Teacher", "Student"]
        },
        "avatar": {
          "type": "string",
          "description": "Emoji representing the user's avatar."
        }
      },
      "required": ["name", "email", "role", "avatar"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "The main document for a quiz session.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["waiting", "live", "finished"]
        },
        "currentQuestionIndex": {
          "type": "number"
        },
        "questionCount": {
          "type": "number"
        },
        "questionStartAt": {
          "type": "number"
        },
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": ["title", "status", "currentQuestionIndex", "questionCount", "createdBy", "createdAt"]
    },
    "QuizQuestion": {
      "title": "QuizQuestion",
      "description": "A single question within a quiz.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timer": {
          "type": "number"
        },
        "index": {
          "type": "number"
        }
      },
      "required": ["text", "options", "timer", "index"]
    },
    "QuizParticipant": {
      "title": "QuizParticipant",
      "description": "A user's state within a quiz.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "score": { "type": "number" },
        "status": { "type": "string", "enum": ["playing", "finished", "blocked"] },
        "violationsCount": { "type": "number" }
      },
      "required": ["name", "avatar", "role", "score", "status", "violationsCount"]
    },
    "QuizSubmission": {
      "title": "QuizSubmission",
      "description": "A student's answer for a question.",
      "type": "object",
      "properties": {
        "selectedOption": { "type": "number" },
        "submittedAt": { "type": "number" }
      },
      "required": ["selectedOption", "submittedAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/quizzes/{quizId}": {
      "schema": { "$ref": "#/entities/Quiz" },
      "description": "Quiz rooms."
    },
    "/quizzes/{quizId}/questions/{questionId}": {
      "schema": { "$ref": "#/entities/QuizQuestion" },
      "description": "Questions in a quiz."
    },
    "/quizzes/{quizId}/participants/{userId}": {
      "schema": { "$ref": "#/entities/QuizParticipant" },
      "description": "Participant state."
    },
    "/quizzes/{quizId}/questions/{questionId}/submissions/{userId}": {
      "schema": { "$ref": "#/entities/QuizSubmission" },
      "description": "Student answers."
    }
  }
}
